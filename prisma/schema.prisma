generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  units       Unit[]
  emissions   EmissionEntry[]
  shipments   Shipment[]
  targets     EmissionTarget[]
  actionPlans ActionPlan[]
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  number    String?
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emissions EmissionEntry[]
  shipments Shipment[]
}

model ReportingPeriod {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emissions EmissionEntry[]
  shipments Shipment[]
}

model EmissionFactor {
  id       String @id @default(cuid())
  name     String
  category String
  scope    Int
  factor   Float
  unit     String
  source   String @default("UK DEFRA")
  year     Int    @default(2024)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emissionEntries EmissionEntry[]
}

model EmissionEntry {
  id             String   @id @default(cuid())
  scope          Int
  sourceName     String
  sourceCategory String
  activityData   Float
  activityUnit   String
  customFactor   Float?
  totalEmissions Float
  notes          String?
  entryDate      DateTime @default(now())

  emissionFactorId  String?
  emissionFactor    EmissionFactor? @relation(fields: [emissionFactorId], references: [id])
  reportingPeriodId String?
  reportingPeriod   ReportingPeriod? @relation(fields: [reportingPeriodId], references: [id])
  siteId            String?
  site              Site?    @relation(fields: [siteId], references: [id])
  unitId            String?
  unit              Unit?    @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id           String  @id @default(cuid())
  name         String
  type         String
  country      String?
  city         String?
  address      String?
  contactName  String?
  contactEmail String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments Shipment[]
}

model Shipment {
  id                 String   @id @default(cuid())
  reference          String?
  direction          String
  productDescription String?
  totalWeightTonnes  Float
  totalEmissions     Float    @default(0)
  notes              String?
  shipmentDate       DateTime @default(now())

  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  reportingPeriodId String?
  reportingPeriod   ReportingPeriod? @relation(fields: [reportingPeriodId], references: [id])
  siteId            String?
  site              Site?    @relation(fields: [siteId], references: [id])
  unitId            String?
  unit              Unit?    @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  legs TransportLeg[]
}

model EmissionTarget {
  id             String  @id @default(cuid())
  year           Int
  scope          Int?
  targetEmissions Float
  baselineYear   Int
  baselineEmissions Float
  siteId         String?
  site           Site?   @relation(fields: [siteId], references: [id])
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionPlans ActionPlan[]
}

model ActionPlan {
  id             String   @id @default(cuid())
  title          String
  description    String?
  status         String   @default("planned") // planned, in_progress, completed, cancelled
  expectedReduction Float
  actualReduction   Float?
  startDate      DateTime?
  targetDate     DateTime?
  completedDate  DateTime?
  siteId         String?
  site           Site?    @relation(fields: [siteId], references: [id])
  targetId       String?
  target         EmissionTarget? @relation(fields: [targetId], references: [id])
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // import, create, update, delete, bulk_delete
  entity    String   // emission, shipment, target, action_plan
  entityId  String?
  details   String?
  count     Int?
  userName  String   @default("Admin")

  createdAt DateTime @default(now())
}

model TransportLeg {
  id             String  @id @default(cuid())
  legOrder       Int
  mode           String
  origin         String?
  destination    String?
  distanceKm     Float
  emissionFactor Float
  emissions      Float
  notes          String?

  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
